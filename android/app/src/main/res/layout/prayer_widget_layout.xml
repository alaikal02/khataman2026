<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/widget_container"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/widget_background"
    android:orientation="vertical"
    android:padding="12dp">

    <!-- Top Info -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal">

        <TextView
            android:id="@+id/prayer_location"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:ellipsize="end"
            android:maxLines="1"
            android:text="Jakarta, Indonesia"
            android:textColor="#E6EDF3"
            android:textSize="12sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/prayer_date"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Senin, 22 Jun"
            android:textColor="#8B949E"
            android:textSize="10sp" />
    </LinearLayout>

    <!-- Next Prayer Callout -->
    <LinearLayout
        android:id="@+id/prayer_next_section"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginTop="6dp"
        android:layout_marginBottom="6dp"
        android:padding="8dp"
        android:background="@drawable/widget_next_prayer_bg"
        android:gravity="center_vertical">

        <TextView
            android:id="@+id/prayer_next_label"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Selanjutnya: Dzuhur"
            android:textColor="#2ECC71"
            android:textSize="13sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/prayer_next_time"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="11:58"
            android:textColor="#E6EDF3"
            android:textSize="18sp"
            android:textStyle="bold" />
    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="#20FFFFFF"
        android:orientation="horizontal"
        android:layout_marginTop="2dp"
        android:layout_marginBottom="4dp" />

    <!-- 5 Prayers Grid -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="horizontal"
        android:weightSum="5">

        <!-- Subuh -->
        <LinearLayout
            android:id="@+id/time_container_subuh"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:gravity="center"
            android:orientation="vertical"
            android:padding="2dp">

            <TextView
                android:id="@+id/time_name_subuh"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Subuh"
                android:textColor="#8B949E"
                android:textSize="9sp" />

            <TextView
                android:id="@+id/time_val_subuh"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:text="04:35"
                android:textColor="#E6EDF3"
                android:textSize="11sp"
                android:textStyle="bold" />
        </LinearLayout>

        <!-- Dzuhur -->
        <LinearLayout
            android:id="@+id/time_container_dzuhur"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:gravity="center"
            android:orientation="vertical"
            android:padding="2dp">

            <TextView
                android:id="@+id/time_name_dzuhur"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Dzuhur"
                android:textColor="#8B949E"
                android:textSize="9sp" />

            <TextView
                android:id="@+id/time_val_dzuhur"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:text="11:58"
                android:textColor="#E6EDF3"
                android:textSize="11sp"
                android:textStyle="bold" />
        </LinearLayout>

        <!-- Ashar -->
        <LinearLayout
            android:id="@+id/time_container_ashar"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:gravity="center"
            android:orientation="vertical"
            android:padding="2dp">

            <TextView
                android:id="@+id/time_name_ashar"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Ashar"
                android:textColor="#8B949E"
                android:textSize="9sp" />

            <TextView
                android:id="@+id/time_val_ashar"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:text="15:20"
                android:textColor="#E6EDF3"
                android:textSize="11sp"
                android:textStyle="bold" />
        </LinearLayout>

        <!-- Maghrib -->
        <LinearLayout
            android:id="@+id/time_container_maghrib"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:gravity="center"
            android:orientation="vertical"
            android:padding="2dp">

            <TextView
                android:id="@+id/time_name_maghrib"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Maghrib"
                android:textColor="#8B949E"
                android:textSize="9sp" />

            <TextView
                android:id="@+id/time_val_maghrib"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:text="17:50"
                android:textColor="#E6EDF3"
                android:textSize="11sp"
                android:textStyle="bold" />
        </LinearLayout>

        <!-- Isya -->
        <LinearLayout
            android:id="@+id/time_container_isya"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:gravity="center"
            android:orientation="vertical"
            android:padding="2dp">

            <TextView
                android:id="@+id/time_name_isya"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Isya"
                android:textColor="#8B949E"
                android:textSize="9sp" />

            <TextView
                android:id="@+id/time_val_isya"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:text="19:05"
                android:textColor="#E6EDF3"
                android:textSize="11sp"
                android:textStyle="bold" />
        </LinearLayout>
    </LinearLayout>
</LinearLayout>
